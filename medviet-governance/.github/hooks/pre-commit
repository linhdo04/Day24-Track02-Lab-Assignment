#!/bin/bash
# Security gate for the MedViet project inside this repository.

set -u

REPO_ROOT="$(git rev-parse --show-toplevel)"
PROJECT_ROOT="$REPO_ROOT/medviet-governance"

echo "Running security checks..."

git secrets --pre_commit_hook -- "$@"
if [ $? -ne 0 ]; then
    echo "git-secrets found a prohibited pattern; commit blocked."
    exit 1
fi

echo "Running Bandit SAST..."
"$PROJECT_ROOT/.venv/bin/bandit" -r "$PROJECT_ROOT/src" -ll -q
if [ $? -ne 0 ]; then
    echo "Bandit found medium/high severity issues; commit blocked."
    exit 1
fi

echo "Checking dependencies for known CVEs..."
export PIP_CACHE_DIR="${TMPDIR:-/tmp}/medviet-pip-cache"
"$PROJECT_ROOT/.venv/bin/pip-audit" \
    --local \
    --cache-dir "${TMPDIR:-/tmp}/medviet-pip-audit-cache" \
    --progress-spinner off
if [ $? -ne 0 ]; then
    echo "pip-audit found vulnerable dependencies; commit blocked."
    exit 1
fi

echo "All security checks passed."
exit 0
